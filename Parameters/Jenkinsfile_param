pipeline {
    agent none
    
    parameters {
        string(name: 'NAME', defaultValue: '', description: 'Please provide the name')
        booleanParam(name: 'TOGGLE', defaultValue: true, description: 'Toggle this value')
        choice(name: 'BRANCH', choices: ['master','staging','prod'], description: 'select from dropdown')
    }
    stages {
        stage ('STAGE1') {
            agent { label 'slave1'}
            steps {

                echo "Name: ${params.NAME}"
                echo "TOGGLE: ${params.TOGGLE}"
                echo "BRANCH TO DEPLOY: ${params.BRANCH}"
            }
        
        }
        stage ('STAGE2') {
            steps {
                echo "Building java code"
                sh '''
                    #!/bin/bash
                    sleep 5
                    '''
            }
        }
}
}
