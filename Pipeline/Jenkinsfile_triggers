pipeline {
    agent any
    
    triggers {
        pollSCM('H/5 * * * *')
    }
    parameters{
        booleanParam(name: 'DEPLOY', description: 'want to deploy to Production')
    }
    environment{
        CURRENT_ENV = 'prod'
    }
    stages {
        stage ('STAGE1 when branch') {

            when {
                allof{
                    branch 'main'
                    expression { params.DEPLOY == true}
                }
                } 
